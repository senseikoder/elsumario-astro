---
import { getCollection } from 'astro:content';

interface Props {
  count?: number;
}

const { count = 4 } = Astro.props;

const posts = (await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const destacadaPosts = posts
  .filter(post => post.data.categories && post.data.categories.includes('destacadas'))
  .slice(0, count);

const cdnBase = 'https://img.efrank.xyz';
const getCdnUrl = (coverImage: string, date: Date) => {
  if (!coverImage) return null;
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  return `${cdnBase}/${year}/${month}/${coverImage}`;
};
---

<section class="destacadas-section">
  <div class="destacadas-grid">
    {destacadaPosts.map((post, index) => {
      const isHero = index === 0;
      const isMedium = index === 1;
      let cardClass = "destacada-card";
      if (isHero) cardClass += " hero";
      else if (isMedium) cardClass += " medium";
      else cardClass += " small";

      return (
        <article class={cardClass}>
          <a href={`/blog/${post.id}`}>
            {post.data.coverImage && (
              <img src={getCdnUrl(post.data.coverImage, post.data.date)} alt={post.data.title} />
            )}
            <div class="card-overlay">
              <h2 class="card-title">{post.data.title}</h2>
            </div>
          </a>
        </article>
      );
    })}
  </div>
</section>

<style>
  .destacadas-section {
    margin-bottom: 24px;
    width: 100%;
  }

  .destacadas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  /* Responsive Grid for Desktop */
  @media (min-width: 768px) {
    .destacadas-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, 220px);
      gap: 8px;
    }

    .destacada-card.hero {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
    }

    .destacada-card.medium {
      grid-column: 3 / 5;
      grid-row: 1 / 2;
    }

    .destacada-card.small:nth-child(3) {
      grid-column: 3 / 4;
      grid-row: 2 / 3;
    }

    .destacada-card.small:nth-child(4) {
      grid-column: 4 / 5;
      grid-row: 2 / 3;
    }
  }

  /* Common Card Styles */
  .destacada-card {
    position: relative;
    overflow: hidden;
    height: 300px; /* fallback for mobile */
    background-color: #1a1a1a;
  }

  @media (min-width: 768px) {
    .destacada-card {
      height: 100%; /* let the grid dictate the height */
    }
  }

  .destacada-card a {
    display: block;
    width: 100%;
    height: 100%;
    color: #ffffff;
    text-decoration: none;
  }

  .destacada-card img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .destacada-card:hover img {
    transform: scale(1.03);
  }

  /* Gradient Overlay */
  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    top: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.3) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 16px;
    box-sizing: border-box;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .destacada-card.hero .card-overlay {
      padding: 24px;
    }
  }

  /* Titles with precise sizing from the image */
  .card-title {
    margin: 0;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-weight: 700;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
    line-height: 1.25;
  }

  /* Font Sizes based on Importance */
  .destacada-card.hero .card-title {
    font-size: 1.4rem;
  }

  .destacada-card.medium .card-title {
    font-size: 1.15rem;
  }

  .destacada-card.small .card-title {
    font-size: 0.95rem;
  }

  @media (min-width: 768px) {
    .destacada-card.hero .card-title {
      font-size: 1.8rem;
    }

    .destacada-card.medium .card-title {
      font-size: 1.3rem;
    }

    .destacada-card.small .card-title {
      font-size: 1.05rem;
    }
  }
</style>