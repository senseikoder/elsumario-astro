---
import { getCollection } from 'astro:content';

interface Props {
  count?: number;
}

const { count = 4 } = Astro.props;

const posts = (await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const loNuestroPosts = posts
  .filter(post => post.data.categories && post.data.categories.includes('perfiles'))
  .slice(0, count);

const cdnBase = 'https://img.efrank.xyz';
const getCdnUrl = (coverImage: string, date: Date) => {
  if (!coverImage) return null;
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  return `${cdnBase}/${year}/${month}/${coverImage}`;
};
---

<section class="lo-nuestro-section">
  <h2 class="section-title">Perfiles</h2>
    <hr class="section-divider" />
  <div class="lo-nuestro-grid">
    {loNuestroPosts.map((post) => (
      <article>
        <a href={`/blog/${post.id}`}>
          {post.data.coverImage && (
            <img src={getCdnUrl(post.data.coverImage, post.data.date)} alt={post.data.title} />
          )}
          <div class="post-content">
            <h3 class="post-title">{post.data.title}</h3>
           
          </div>
        </a>
      </article>
    ))}
  </div>
</section>

<style>
  .lo-nuestro-section {
    margin-bottom: 2rem;
  }

  .lo-nuestro-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .lo-nuestro-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .lo-nuestro-grid {
      grid-template-columns: 1fr;
    }
  }



  article img {
    width: 100%;
    height: 150px;
    object-fit: cover;
  }

  .post-content {
    padding: 0.75rem;
  }


</style>