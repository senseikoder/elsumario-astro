---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, categories, coverImage } = post.data;

const cdnBase = 'https://img.efrank.xyz';
const year = date.getFullYear();
const month = String(date.getMonth() + 1).padStart(2, '0');
const cdnImage = coverImage ? `${cdnBase}/${year}/${month}/${coverImage}` : null;
---

<BaseLayout title={title} description={description}>
  <article class="blog-post">
    <header class="post-header">
      <div class="container">
        {categories && categories.length > 0 && (
          <nav class="post-categories">
            {categories.map((cat) => (
              <a href={`/blog/categoria/${cat}`}>{cat}</a>
            ))}
          </nav>
        )}
        <h1>{title}</h1>
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('es-ES', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          })}
        </time>
        {cdnImage && (
          <img src={cdnImage} alt={title} class="featured-image" />
        )}
      </div>
    </header>

    <div class="post-content container">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .post-categories {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .post-categories a {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .post-header h1 {
    font-size: 2.5rem;
    margin: 0.5rem 0;
    line-height: 1.2;
  }

  .post-header time {
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .featured-image {
    margin-top: 1.5rem;
    max-height: 500px;
    object-fit: cover;
    border-radius: 8px;
  }

  .post-content {
    max-width: 800px;
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
    margin-top: 2rem;
  }

  .post-content :global(h3) {
    font-size: 1.5rem;
    margin-top: 1.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }
</style>
